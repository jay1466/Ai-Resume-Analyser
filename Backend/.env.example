# ==========================================
# Deployment Environment Variables Template
# ==========================================
# Replace the placeholder values with your actual keys.
# Do NOT commit your actual .env file to GitHub.

# 1. Database Configuration (e.g., Aiven, Clever Cloud, local MySQL)
url=jdbc:mysql://your_db_host:3306/your_db_name?sslMode=REQUIRED
uname=your_db_user
upass=your_db_password

# 2. Google Gemini AI API Key (For Resume Analysis)
genkey=your_gemini_api_key

# 3. Brevo Mail API Key (For Email Verification & Password Reset)
mailkey=your_brevo_mail_key
senderemail=your_verified_brevo_email@gmail.com

# 4. Adzuna API Credentials (For Job Suggestions)
adzunaid=your_adzuna_app_id
adzunakey=your_adzuna_api_key

# 5. Google Cloud Platform Credentials (For Google Sign-In / OAuth2)
gcpid=your_gcp_client_id.apps.googleusercontent.com
gcpsecret=your_gcp_client_secret

# 6. JWT Secret Key (Generate a random secure string)
jwtkey=your_random_jwt_secret

# 7. Server Port (Render dynamically assigns this, but useful for local testing)
# PORT=8080
